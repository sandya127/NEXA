# ------------------------------------------------
#   MUSIC SKILL  (play song on YouTube or Spotify)
# ------------------------------------------------
class MusicSkill(Skill):
    triggers = [
        "play",
        "play song",
        "play music",
        "play on youtube",
        "play on spotify",
    ]

    def __init__(self, listener: Listener) -> None:
        self._listener = listener

    @staticmethod
    def _extract_song(query: str) -> tuple[str, str]:
        """Returns (song_name, platform) — platform is 'youtube' or 'spotify'."""

        # Detect platform
        if "spotify" in query:
            platform = "spotify"
        else:
            platform = "youtube"   # default to YouTube

        # Strip filler words to isolate the song name
        song = query
        for phrase in [
            "nexa", "play", "on spotify", "on youtube", "in spotify",
            "in youtube", "spotify", "youtube", "song", "track", "music",
            "please", "for me",
        ]:
            song = song.replace(phrase, "")

        song = song.strip()
        return song, platform

    def run(self, query: str, speaker: Speaker) -> None:
        song, platform = self._extract_song(query)

        # If song name is empty after stripping, ask the user
        if not song:
            speaker.say("What song would you like me to play?")
            song = self._listener.listen()
            if not song:
                speaker.say("I didn't catch the song name. Please try again.")
                return

        encoded = urllib.parse.quote(song)  # URL-safe encode song name

        if platform == "spotify":
            # Opens Spotify Web Player search — no app needed
            url = f"https://open.spotify.com/search/{encoded}"
            speaker.say(f"Playing {song} on Spotify.")
            log.info("Opening Spotify: %s", url)
            webbrowser.open(url)

        else:
            # Opens YouTube search results for the song
            url = f"https://www.youtube.com/results?search_query={encoded}"
            speaker.say(f"Playing {song} on YouTube.")
            log.info("Opening YouTube: %s", url)
            webbrowser.open(url)

#----------------------------------------
# RemainderSkill
#----------------------------------------
class ReminderSkill(Skill):
    triggers = ["remind me", "set reminder", "reminder"]

    def __init__(self, listener: Listener) -> None:
        self._listener = listener

    @staticmethod
    def _parse_time(text: str) -> datetime.datetime | None:
        now = datetime.datetime.now()

        pattern = re.compile(
            r"""
            (\d{1,2})           # hour
            [:\s]?              # optional colon or space
            (\d{2})?            # optional minutes
            \s*
            (am|pm)?            # optional am/pm
            """,
            re.VERBOSE | re.IGNORECASE,
        )

        match = pattern.search(text)
        if not match:
            return None

        hour   = int(match.group(1))
        minute = int(match.group(2)) if match.group(2) else 0
        ampm   = match.group(3).lower() if match.group(3) else None

        if ampm == "pm" and hour != 12:
            hour += 12
        elif ampm == "am" and hour == 12:
            hour = 0
        elif ampm is None and 1 <= hour <= 7:
            hour += 12

        try:
            target = now.replace(hour=hour, minute=minute, second=0, microsecond=0)
        except ValueError:
            return None

        if target <= now:
            target += datetime.timedelta(days=1)

        return target

    def _fire_at(self, target: datetime.datetime, about: str, speaker: Speaker) -> None:
        def _wait_and_fire():
            delay = (target - datetime.datetime.now()).total_seconds()
            if delay > 0:
                time.sleep(delay)
            log.info("Firing reminder: %s", about)
            speaker.say(f"Reminder: {about}")

        t = threading.Thread(target=_wait_and_fire, daemon=True)
        t.start()

    def run(self, query: str, speaker: Speaker) -> None:
        about = ""
        for prep in ("about", "for", "to"):
            m = re.search(rf"{prep}\s+(.+?)(?:\s+at\s+|\s+by\s+|\s*$)", query)
            if m:
                about = m.group(1).strip()
                break

        if not about:
            speaker.say("What should I remind you about?")
            about = self._listener.listen() or "something important"

        target = self._parse_time(query)

        if target is None:
            speaker.say("At what time should I remind you?")
            time_query = self._listener.listen()
            target = self._parse_time(time_query)

        if target is None:
            speaker.say("I couldn't catch the time. I'll remind you in 60 seconds.")
            target = datetime.datetime.now() + datetime.timedelta(seconds=60)

        time_str = target.strftime("%I:%M %p")
        speaker.say(f"Got it. I'll remind you about '{about}' at {time_str}.")
        log.info("Reminder scheduled: '%s' at %s", about, time_str)

        self._fire_at(target, about, speaker)


