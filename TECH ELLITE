class GoogleSpeechServices:
    """Google Cloud Speech-to-Text and Text-to-Speech"""
    
    def __init__(self, credentials_path: str = ""):
        self.enabled = GOOGLE_AVAILABLE and os.path.exists(credentials_path)
        
        if self.enabled:
            try:
                credentials = service_account.Credentials.from_service_account_file(
                    credentials_path
                )
                self.tts_client = texttospeech.TextToSpeechClient(credentials=credentials)
                self.stt_client = speech.SpeechClient(credentials=credentials)
                log.info("Google Speech Services initialized")
            except Exception as e:
                log.error(f"Failed to initialize Google services: {e}")
                self.enabled = False
        else:
            log.warning("Google Speech Services disabled")
    
    def text_to_speech(self, text: str, voice_name: str = "en-US-Neural2-F") -> bytes:
        """Convert text to speech audio"""
        if not self.enabled:
            return b""
        
        try:
            synthesis_input = texttospeech.SynthesisInput(text=text)
            
            voice = texttospeech.VoiceSelectionParams(
                language_code="en-US",
                name=voice_name
            )
            
            audio_config = texttospeech.AudioConfig(
                audio_encoding=texttospeech.AudioEncoding.LINEAR16,
                speaking_rate=1.0,
                pitch=0.0
            )
            
            response = self.tts_client.synthesize_speech(
                input=synthesis_input,
                voice=voice,
                audio_config=audio_config
            )
            
            return response.audio_content
        except Exception as e:
            log.error(f"TTS error: {e}")
            return b""
    
    def speech_to_text(self, audio_data: bytes, sample_rate: int = 16000) -> str:
        """Convert speech audio to text"""
        if not self.enabled:
            return ""
        
        try:
            audio = speech.RecognitionAudio(content=audio_data)
            
            config = speech.RecognitionConfig(
                encoding=speech.RecognitionConfig.AudioEncoding.LINEAR16,
                sample_rate_hertz=sample_rate,
                language_code="en-IN",
                enable_automatic_punctuation=True
            )
            
            response = self.stt_client.recognize(config=config, audio=audio)
            
            if response.results:
                return response.results[0].alternatives[0].transcript
            return ""
        except Exception as e:
            log.error(f"STT error: {e}")
            return ""

