#   EMOTION DETECTOR
# ──────────────────────────────────────────────────────────────────
class EmotionDetector:
    """Detects emotion from audio features"""
    
    def __init__(self):
        self.enabled = EMOTION_AVAILABLE
    
    def analyze_audio(self, audio_data: bytes, sample_rate: int = 16000) -> str:
        """Analyze audio and return emotion"""
        if not self.enabled:
            return 'neutral'
        
        try:
            audio_np = np.frombuffer(audio_data, dtype=np.int16).astype(np.float32)
            audio_np = audio_np / np.max(np.abs(audio_np) + 1e-8)
            
            pitch = self._extract_pitch(audio_np, sample_rate)
            energy = self._extract_energy(audio_np)
            speech_rate = self._estimate_speech_rate(audio_np, sample_rate)
            
            emotion = self._classify_emotion(pitch, energy, speech_rate)
            return emotion
        except Exception as e:
            log.error(f"Emotion detection error: {e}")
            return 'neutral'
    
    def _extract_pitch(self, audio: np.ndarray, sr: int) -> float:
        try:
            pitches, magnitudes = librosa.piptrack(y=audio, sr=sr)
            pitch_values = []
            for t in range(pitches.shape[1]):
                index = magnitudes[:, t].argmax()
                pitch = pitches[index, t]
                if pitch > 0:
                    pitch_values.append(pitch)
            return np.mean(pitch_values) if pitch_values else 150.0
        except:
            return 150.0
    
    def _extract_energy(self, audio: np.ndarray) -> float:
        return float(np.sqrt(np.mean(audio**2)))
    
    def _estimate_speech_rate(self, audio: np.ndarray, sr: int) -> float:
        try:
            onset_env = librosa.onset.onset_strength(y=audio, sr=sr)
            tempo = librosa.beat.tempo(onset_envelope=onset_env, sr=sr)[0]
            return tempo / 60.0
        except:
            return 2.0
    
    def _classify_emotion(self, pitch: float, energy: float, speech_rate: float) -> str:
        pitch_score = (pitch - 150) / 50
        energy_score = energy / 0.1
        rate_score = (speech_rate - 2.0) / 1.0
        
        if energy_score < 0.5 and pitch_score < -0.5 and rate_score < -0.3:
            return 'sad'
        elif pitch_score > 1.0 and energy_score > 1.5 and rate_score > 0.5:
            if energy_score > 2.0:
                return 'angry'
            return 'stressed'
        elif pitch_score > 0.3 and energy_score > 0.8 and -0.2 < rate_score < 0.5:
            return 'happy'
        else:
            return 'neutral'

