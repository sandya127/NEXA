// ══════════════════════════════════════════════
//   MIC — FULL FIX
// ══════════════════════════════════════════════
function toggleMic() {
  if (micActive) { stopMic(); return; }
  startMic();
}

function startMic() {
  const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;

  // FIX 1: clear browser support check with helpful message
  if (!SpeechRec) {
    showToast('Speech recognition not supported. Please use Chrome or Edge.', 'error');
    return;
  }

  // FIX 2: stop TTS before listening so mic doesn't pick up Nexa's voice
  if (synth) synth.cancel();

  // FIX 3: abort any existing recognition before creating a new one
  if (recognition) {
    try { recognition.abort(); } catch(e) {}
    recognition = null;
  }

  recognition     = new SpeechRec();
  resultReceived  = false;          // reset guard flag

  recognition.lang            = 'en-IN';
  recognition.interimResults  = true;   // FIX 4: show live transcript as user speaks
  recognition.maxAlternatives = 1;
  recognition.continuous      = false;

  // ── onstart ──────────────────────────────────────
  recognition.onstart = () => {
    micActive = true;
    resultReceived = false;
    document.getElementById('micBtn').classList.add('active');
    document.getElementById('waveform').classList.remove('idle');
    document.getElementById('micStatus').innerHTML = '🎙 <strong>Listening… Speak Now</strong>';
    document.getElementById('interimText').textContent = '';
    document.getElementById('chatInput').placeholder   = '🎤 Listening…';
    document.getElementById('globalStatus').textContent = 'Listening';
    voiceCount++;
    document.getElementById('statVoice').textContent = voiceCount;
  };

  // ── onresult — FIX 5: handle interim + final correctly ──
  recognition.onresult = (event) => {
    let interim = '';
    let final   = '';

    for (let i = event.resultIndex; i < event.results.length; i++) {
      const transcript = event.results[i][0].transcript;
      if (event.results[i].isFinal) {
        final += transcript;
      } else {
        interim += transcript;
      }
    }

    // Show live interim text so user knows it's working
    if (interim) {
      document.getElementById('interimText').textContent = interim;
      document.getElementById('interimText').classList.remove('final');
    }

    // When final result arrives, send to Nexa
    if (final.trim()) {
      resultReceived = true;
      document.getElementById('interimText').textContent = final;
      document.getElementById('interimText').classList.add('final');
      document.getElementById('micStatus').innerHTML = `Heard: <strong>${escHtml(final)}</strong>`;
      // FIX 6: stop mic BEFORE processing so onend doesn't race with processInput
      stopMic();
      processInput(final.trim());
    }
  };

  // ── onerror — FIX 7: meaningful per-error messages ──
  recognition.onerror = (event) => {
    resultReceived = true; // prevent onend from showing "no result"
    const msgs = {
      'not-allowed':         '🔒 Mic blocked. Click the 🔒 icon in your browser address bar and Allow microphone.',
      'no-speech':           '🔇 No speech detected. Please speak clearly and try again.',
      'audio-capture':       '🎙 No microphone found. Please connect a mic and refresh.',
      'network':             '🌐 Network error. Check your internet and try again.',
      'service-not-allowed': '🔒 Speech service blocked. Use Chrome/Edge on localhost.',
      'aborted':             '',  // user manually stopped — silent
    };
    const msg = msgs[event.error];
    if (msg) {
      showToast(msg, 'error');
      document.getElementById('micStatus').innerHTML = `<span style="color:#ff6450">${msg}</span>`;
    }
    console.warn('STT error:', event.error);
    stopMic();
  };

  // ── onend — FIX 8: only resets UI, doesn't double-process ──
  recognition.onend = () => {
    // If we never got a result and no error, let user know
    if (!resultReceived) {
      document.getElementById('micStatus').innerHTML = '🔇 Nothing heard. Tap to <strong>Try Again</strong>';
    }
    _resetMicUI();
  };

  // FIX 9: wrap start() in try/catch — some browsers throw on second call
  try {
    recognition.start();
  } catch (err) {
    showToast('Could not start microphone. Please reload and allow mic access.', 'error');
    _resetMicUI();
    console.error('recognition.start() failed:', err);
  }
}

function stopMic() {
  if (recognition) {
    try { recognition.stop(); } catch(e) {}
    // Don't null it yet — onend will fire after stop() and needs the flag
  }
  _resetMicUI();
}

// FIX 10: separate UI reset from logic so it can be called safely from both paths
function _resetMicUI() {
  micActive = false;
  document.getElementById('micBtn').classList.remove('active');
  document.getElementById('waveform').classList.add('idle');
  document.getElementById('chatInput').placeholder = 'Type a message or use voice…';
  document.getElementById('globalStatus').textContent = 'Online';
  document.getElementById('interimText').classList.remove('final');
  // Clear interim text after a moment so user can read the final result
  setTimeout(() => {
    if (!micActive) document.getElementById('interimText').textContent = '';
  }, 2000);
}

// ══════════════════════════════════════════════
//   TOAST
// ══════════════════════════════════════════════
function showToast(msg, type = 'error') {
  if (!msg) return;
  const t = document.createElement('div');
  t.className = `voice-toast ${type}`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 5000);
}
