    FILES = {
        "notepad": "notepad.exe",
        "calculator": "calc.exe",
        "music": os.path.join(USER_HOME, "Music", "song.mp3"),
    }

    triggers = [f"open {k}" for k in FILES]

    def run(self, query: str, speaker: Speaker) -> None:
        for name, path in self.FILES.items():
            if name in query:
                try:
                    if path.endswith(".exe"):
                        subprocess.Popen(path)
                    else:
                        if os.path.exists(path):
                            os.startfile(path)
                        else:
                            speaker.say(f"I couldn't find {name} file.")
                            return
                    speaker.say(f"Opening {name}")
                except Exception as e:
                    speaker.say("Something went wrong while opening.")
                return

