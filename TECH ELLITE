class WebSkill(Skill):
    SITES = {
        "youtube": "https://youtube.com",
        "google": "https://google.com",
        "gmail": "https://mail.google.com",
        "github": "https://github.com",
        "maps": "https://maps.google.com",
        "netflix": "https://netflix.com",
        "spotify": "https://spotify.com",
        "amazon": "https://amazon.in",
        "instagram": "https://instagram.com",
        "linkedin": "https://linkedin.com",
        "twitter": "https://twitter.com",
    }
    
    triggers = [f"open {k}" for k in SITES.keys()]
    
    def run(self, query: str, nexa_app) -> str:
        for keyword, url in self.SITES.items():
            if keyword in query.lower():
                webbrowser.open(url)
                return f"Opening {keyword}"
        return "Which website would you like to open?"

class SearchSkill(Skill):
    triggers = ["search", "google", "find", "look up"]
    
    def run(self, query: str, nexa_app) -> str:
        # Extract search query
        for trigger in self.triggers:
            if trigger in query.lower():
                search_query = query.lower().replace(trigger, "").strip()
                if search_query:
                    encoded = urllib.parse.quote(search_query)
                    webbrowser.open(f"https://www.google.com/search?q={encoded}")
                    return f"Searching for {search_query}"
        return "What would you like me to search for?"

