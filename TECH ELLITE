<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nexa Voice Assistant</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #050A0F;
    --bg-surface: #0A1219;
    --bg-card: #0D1820;
    --bg-input: #111E28;
    --cyan: #00E5FF;
    --cyan-dim: rgba(0, 229, 255, 0.15);
    --cyan-mid: rgba(0, 229, 255, 0.35);
    --cyan-glow: rgba(0, 229, 255, 0.08);
    --text-primary: #E8F4F8;
    --text-secondary: #6A8FA8;
    --text-muted: #3A5A72;
    --border: rgba(0, 229, 255, 0.1);
    --border-strong: rgba(0, 229, 255, 0.25);
    --user-bubble: #0F2A3A;
    --nexa-bubble: #091520;
    --radius: 16px;
    --radius-sm: 10px;
    --radius-xl: 24px;
  }

  body {
    font-family: 'Syne', sans-serif;
    background: var(--bg);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
    pointer-events: none;
    z-index: 999;
  }

  .ambient { position: fixed; border-radius: 50%; filter: blur(80px); pointer-events: none; z-index: 0; }
  .ambient-1 { width: 500px; height: 500px; background: rgba(0, 229, 255, 0.04); top: -100px; left: 50%; transform: translateX(-50%); }
  .ambient-2 { width: 300px; height: 300px; background: rgba(0, 100, 200, 0.06); bottom: 0; right: -100px; }

  .shell {
    position: relative; z-index: 1;
    display: flex; flex-direction: column;
    min-height: 100vh;
    max-width: 1100px; margin: 0 auto; padding: 0 24px;
  }

  header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 0; border-bottom: 1px solid var(--border);
  }

  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-mark {
    width: 36px; height: 36px; border: 1.5px solid var(--cyan);
    border-radius: 10px; display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .logo-mark::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(0,229,255,0.15), transparent);
  }
  .logo-mark svg { width: 18px; height: 18px; }
  .logo-name { font-size: 22px; font-weight: 800; letter-spacing: -0.5px; color: var(--text-primary); }
  .logo-name span { color: var(--cyan); }
  .logo-tag { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--text-muted); letter-spacing: 2px; text-transform: uppercase; }

  .header-right { display: flex; align-items: center; gap: 12px; }

  .status-badge {
    font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--cyan); background: var(--cyan-dim);
    border: 1px solid var(--border-strong); padding: 4px 10px; border-radius: 20px;
    display: flex; align-items: center; gap: 6px;
  }
  .status-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--cyan); animation: pulse-dot 2s ease-in-out infinite; }
  @keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

  .icon-btn {
    width: 36px; height: 36px; border: 1px solid var(--border); border-radius: var(--radius-sm);
    background: var(--bg-card); display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--text-secondary); transition: border-color 0.2s, color 0.2s;
  }
  .icon-btn:hover { border-color: var(--border-strong); color: var(--cyan); }
  .icon-btn svg { width: 16px; height: 16px; }

  .main {
    flex: 1; display: grid; grid-template-columns: 1fr 340px;
    gap: 20px; padding: 24px 0; align-items: start;
  }

  .left-panel { display: flex; flex-direction: column; gap: 20px; }

  /* MIC SECTION */
  .mic-section {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-xl); padding: 40px 32px;
    display: flex; flex-direction: column; align-items: center; gap: 24px;
    position: relative; overflow: hidden;
  }
  .mic-section::before {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 80%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan-mid), transparent);
  }

  .mic-label { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--text-muted); }

  /* WAVEFORM */
  .waveform { display: flex; align-items: center; gap: 3px; height: 40px; }
  .wave-bar { width: 3px; background: var(--cyan); border-radius: 2px; animation: wave 1.4s ease-in-out infinite; opacity: 0.6; }
  .wave-bar:nth-child(1)  { height: 8px;  animation-delay: 0.0s; }
  .wave-bar:nth-child(2)  { height: 16px; animation-delay: 0.1s; }
  .wave-bar:nth-child(3)  { height: 28px; animation-delay: 0.2s; }
  .wave-bar:nth-child(4)  { height: 36px; animation-delay: 0.3s; }
  .wave-bar:nth-child(5)  { height: 40px; animation-delay: 0.4s; }
  .wave-bar:nth-child(6)  { height: 32px; animation-delay: 0.5s; }
  .wave-bar:nth-child(7)  { height: 24px; animation-delay: 0.6s; }
  .wave-bar:nth-child(8)  { height: 18px; animation-delay: 0.7s; }
  .wave-bar:nth-child(9)  { height: 30px; animation-delay: 0.6s; }
  .wave-bar:nth-child(10) { height: 38px; animation-delay: 0.5s; }
  .wave-bar:nth-child(11) { height: 26px; animation-delay: 0.4s; }
  .wave-bar:nth-child(12) { height: 14px; animation-delay: 0.3s; }
  .wave-bar:nth-child(13) { height: 8px;  animation-delay: 0.2s; }
  @keyframes wave { 0%, 100% { transform: scaleY(0.4); opacity: 0.4; } 50% { transform: scaleY(1.0); opacity: 1.0; } }
  .waveform.idle .wave-bar { animation: none; height: 4px !important; opacity: 0.2; transition: height 0.3s; }

  /* MIC BUTTON */
  .mic-ring-outer { position: relative; width: 140px; height: 140px; display: flex; align-items: center; justify-content: center; }
  .mic-ring-pulse { position: absolute; inset: 0; border-radius: 50%; border: 1.5px solid rgba(0, 229, 255, 0.3); animation: ring-expand 2.5s ease-out infinite; }
  .mic-ring-pulse:nth-child(2) { animation-delay: 0.8s; }
  .mic-ring-pulse:nth-child(3) { animation-delay: 1.6s; }
  @keyframes ring-expand { 0% { transform: scale(1); opacity: 0.7; } 100% { transform: scale(1.7); opacity: 0; } }
  .mic-ring { position: absolute; inset: 12px; border-radius: 50%; border: 1px solid var(--border-strong); }
  .mic-btn {
    position: relative; z-index: 2; width: 96px; height: 96px; border-radius: 50%;
    background: linear-gradient(145deg, #0A1C28, #051018); border: 2px solid var(--cyan);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 0 0 30px rgba(0, 229, 255, 0.2), inset 0 0 20px rgba(0, 229, 255, 0.05);
  }
  .mic-btn:hover { transform: scale(1.05); box-shadow: 0 0 50px rgba(0, 229, 255, 0.35), inset 0 0 30px rgba(0, 229, 255, 0.08); }
  .mic-btn:active { transform: scale(0.97); }
  .mic-btn.active {
    background: linear-gradient(145deg, #00293A, #001A24); border-color: var(--cyan);
    box-shadow: 0 0 60px rgba(0, 229, 255, 0.5), inset 0 0 30px rgba(0, 229, 255, 0.12);
    animation: mic-listening-pulse 1s ease-in-out infinite;
  }
  /* FIX: add pulsing animation when actively listening */
  @keyframes mic-listening-pulse {
    0%, 100% { box-shadow: 0 0 40px rgba(0,229,255,0.4), inset 0 0 20px rgba(0,229,255,0.1); }
    50%       { box-shadow: 0 0 80px rgba(0,229,255,0.7), inset 0 0 40px rgba(0,229,255,0.2); }
  }
  .mic-btn svg { width: 36px; height: 36px; color: var(--cyan); }
  .mic-status { font-size: 13px; color: var(--text-secondary); letter-spacing: 0.5px; text-align: center; min-height: 20px; }
  .mic-status strong { color: var(--cyan); font-weight: 600; }

  /* interim transcript display */
  .interim-text {
    font-family: 'DM Mono', monospace; font-size: 12px; color: var(--text-muted);
    text-align: center; min-height: 16px; font-style: italic;
    transition: color 0.2s;
  }
  .interim-text.final { color: var(--cyan); }

  /* QUICK ACTIONS */
  .quick-actions { display: flex; gap: 8px; flex-wrap: wrap; }
  .qa-btn {
    flex: 1; min-width: 80px; padding: 10px 12px; background: var(--bg-card);
    border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-secondary);
    font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.5px;
    cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 6px;
    transition: all 0.2s ease; text-decoration: none;
  }
  .qa-btn:hover { border-color: var(--border-strong); color: var(--cyan); background: var(--cyan-glow); transform: translateY(-1px); }
  .qa-btn svg { width: 18px; height: 18px; }

  /* CHAT PANEL */
  .chat-panel {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-xl); display: flex; flex-direction: column;
    height: 520px; position: relative; overflow: hidden;
  }
  .chat-panel::before {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 80%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan-mid), transparent);
  }
  .chat-header { padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
  .chat-title { font-size: 13px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--text-secondary); }
  .chat-count { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--text-muted); background: var(--bg-surface); border: 1px solid var(--border); padding: 2px 8px; border-radius: 20px; }
  .chat-messages {
    flex: 1; overflow-y: auto; padding: 16px;
    display: flex; flex-direction: column; gap: 12px;
    scrollbar-width: thin; scrollbar-color: var(--border) transparent;
  }
  .msg { display: flex; gap: 8px; align-items: flex-end; animation: msg-in 0.3s ease; }
  @keyframes msg-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .msg.user { flex-direction: row-reverse; }
  .msg-avatar {
    width: 28px; height: 28px; border-radius: 8px; border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-size: 11px; font-weight: 700;
  }
  .msg-avatar.nexa { background: var(--cyan-dim); border-color: var(--border-strong); color: var(--cyan); }
  .msg-avatar.user-av { background: #152030; color: var(--text-secondary); }
  .msg-content { max-width: 85%; display: flex; flex-direction: column; gap: 4px; }
  .msg.user .msg-content { align-items: flex-end; }
  .msg-bubble { padding: 10px 14px; border-radius: 14px; font-size: 13px; line-height: 1.6; }
  .msg.nexa .msg-bubble { background: var(--nexa-bubble); border: 1px solid var(--border); border-bottom-left-radius: 4px; color: var(--text-primary); }
  .msg.user .msg-bubble { background: var(--user-bubble); border: 1px solid rgba(0,229,255,0.2); border-bottom-right-radius: 4px; color: var(--text-primary); }
  .msg-meta { display: flex; align-items: center; gap: 6px; font-family: 'DM Mono', monospace; font-size: 10px; color: var(--text-muted); }
  .emotion-badge { display: flex; align-items: center; gap: 3px; font-size: 10px; padding: 2px 6px; border-radius: 8px; font-family: 'DM Mono', monospace; }
  .emotion-badge.happy  { background: rgba(0,255,140,0.08);  color: #00e07a; border: 1px solid rgba(0,255,140,0.15); }
  .emotion-badge.info   { background: rgba(0,229,255,0.08);  color: var(--cyan); border: 1px solid var(--border); }
  .emotion-badge.think  { background: rgba(200,160,255,0.08); color: #c8a0ff; border: 1px solid rgba(200,160,255,0.15); }
  .emotion-badge.fun    { background: rgba(255,200,0,0.08);  color: #ffc800; border: 1px solid rgba(255,200,0,0.15); }
  .emotion-badge.remind { background: rgba(255,100,80,0.08); color: #ff6450; border: 1px solid rgba(255,100,80,0.15); }
  .emotion-badge.music  { background: rgba(0,200,100,0.08);  color: #00c864; border: 1px solid rgba(0,200,100,0.15); }

  /* TYPING INDICATOR */
  .typing-indicator {
    display: flex; gap: 4px; align-items: center; padding: 10px 14px;
    background: var(--nexa-bubble); border: 1px solid var(--border);
    border-radius: 14px; border-bottom-left-radius: 4px; width: fit-content;
  }
  .typing-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--text-muted); animation: bounce 1.2s ease infinite; }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-6px); background: var(--cyan); } }

  /* CHAT INPUT */
  .chat-input-area { padding: 12px 16px; border-top: 1px solid var(--border); display: flex; gap: 10px; align-items: center; }
  .chat-input {
    flex: 1; background: var(--bg-input); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 9px 14px;
    font-family: 'Syne', sans-serif; font-size: 13px; color: var(--text-primary);
    outline: none; transition: border-color 0.2s;
  }
  .chat-input::placeholder { color: var(--text-muted); }
  .chat-input:focus { border-color: var(--border-strong); }
  .send-btn {
    width: 36px; height: 36px; background: var(--cyan-dim);
    border: 1px solid var(--border-strong); border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--cyan); transition: all 0.2s; flex-shrink: 0;
  }
  .send-btn:hover { background: rgba(0,229,255,0.25); }
  .send-btn svg { width: 15px; height: 15px; }

  /* RIGHT PANEL */
  .right-panel { display: flex; flex-direction: column; gap: 16px; }

  .info-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-xl); padding: 20px; position: relative; overflow: hidden;
  }
  .info-card::before {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 80%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan-mid), transparent);
  }
  .card-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 12px; }

  /* CLOCK */
  .clock-display { font-family: 'DM Mono', monospace; font-size: 42px; font-weight: 300; color: var(--text-primary); letter-spacing: -1px; line-height: 1; }
  .clock-display span { color: var(--cyan); }
  .clock-date { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text-muted); margin-top: 6px; }

  /* REMINDERS */
  .reminders-list { display: flex; flex-direction: column; gap: 8px; }
  .reminder-item {
    display: flex; align-items: center; gap: 10px; padding: 10px 12px;
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: var(--radius-sm); cursor: pointer; transition: border-color 0.2s;
    animation: msg-in 0.3s ease;
  }
  .reminder-item:hover { border-color: var(--border-strong); }
  .reminder-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .rd-cyan  { background: var(--cyan); box-shadow: 0 0 8px rgba(0,229,255,0.6); }
  .rd-green { background: #00e07a; box-shadow: 0 0 8px rgba(0,224,122,0.5); }
  .rd-amber { background: #ffc800; box-shadow: 0 0 8px rgba(255,200,0,0.5); }
  .reminder-text { flex: 1; font-size: 12px; color: var(--text-secondary); }
  .reminder-time { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--text-muted); }
  .reminder-empty { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text-muted); text-align: center; padding: 12px 0; }

  /* STATS */
  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .stat-cell { background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 12px; }
  .stat-num { font-family: 'DM Mono', monospace; font-size: 24px; font-weight: 400; color: var(--cyan); line-height: 1; }
  .stat-lbl { font-size: 10px; color: var(--text-muted); margin-top: 4px; letter-spacing: 0.5px; }

  /* VOICE ERROR TOAST */
  .voice-toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
    font-family: 'DM Mono', monospace; font-size: 12px;
    padding: 10px 20px; border-radius: 10px; z-index: 9999;
    animation: msg-in 0.3s ease;
  }
  .voice-toast.error   { background: #1a0a0a; border: 1px solid rgba(255,80,80,0.4); color: #ff6060; }
  .voice-toast.success { background: #0a1a0f; border: 1px solid rgba(0,229,100,0.4); color: #00e064; }

  /* MOBILE SHOWCASE */
  .divider { border: none; border-top: 1px solid var(--border); margin: 40px 0 32px; }
  .section-header { display: flex; align-items: center; gap: 16px; margin-bottom: 28px; }
  .section-label { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--text-muted); white-space: nowrap; }
  .section-line { flex: 1; height: 1px; background: var(--border); }

  .mobile-showcase { display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; padding-bottom: 60px; }
  .mobile-frame { width: 280px; border-radius: 36px; border: 2px solid var(--border-strong); background: var(--bg); overflow: hidden; position: relative; box-shadow: 0 0 60px rgba(0,229,255,0.08); }
  .mobile-notch { width: 90px; height: 22px; background: var(--bg); border-radius: 0 0 14px 14px; margin: 0 auto; position: relative; z-index: 10; border-left: 2px solid var(--border-strong); border-right: 2px solid var(--border-strong); border-bottom: 2px solid var(--border-strong); }
  .mobile-screen { padding: 8px 12px 20px; }
  .mobile-header { display: flex; align-items: center; justify-content: space-between; padding: 8px 0 14px; border-bottom: 1px solid var(--border); margin-bottom: 12px; }
  .m-logo { font-size: 15px; font-weight: 800; color: var(--text-primary); }
  .m-logo span { color: var(--cyan); }
  .m-status { font-family: 'DM Mono', monospace; font-size: 8px; color: var(--cyan); background: var(--cyan-dim); border: 1px solid var(--border-strong); padding: 2px 6px; border-radius: 10px; display: flex; align-items: center; gap: 4px; }
  .m-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--cyan); animation: pulse-dot 2s ease-in-out infinite; }
  .m-msgs { display: flex; flex-direction: column; gap: 8px; }
  .m-msg { display: flex; gap: 6px; align-items: flex-end; }
  .m-msg.user { flex-direction: row-reverse; }
  .m-av { width: 22px; height: 22px; border-radius: 6px; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 8px; font-weight: 700; flex-shrink: 0; }
  .m-av.nexa { background: var(--cyan-dim); border-color: var(--border-strong); color: var(--cyan); }
  .m-av.usr  { background: #152030; color: var(--text-secondary); }
  .m-bubble { max-width: 78%; padding: 7px 10px; border-radius: 10px; font-size: 10px; line-height: 1.5; }
  .m-msg.nexa .m-bubble { background: var(--nexa-bubble); border: 1px solid var(--border); border-bottom-left-radius: 3px; color: var(--text-primary); }
  .m-msg.user .m-bubble { background: var(--user-bubble); border: 1px solid rgba(0,229,255,0.2); border-bottom-right-radius: 3px; color: var(--text-primary); }
  .m-input-row { display: flex; gap: 6px; align-items: center; border-top: 1px solid var(--border); padding-top: 10px; margin-top: 2px; }
  .m-input { flex: 1; background: var(--bg-input); border: 1px solid var(--border); border-radius: 7px; padding: 6px 10px; font-size: 10px; color: var(--text-muted); font-family: 'Syne', sans-serif; }
  .m-send { width: 26px; height: 26px; background: var(--cyan-dim); border: 1px solid var(--border-strong); border-radius: 7px; display: flex; align-items: center; justify-content: center; color: var(--cyan); }
  .m-send svg { width: 11px; height: 11px; }
  .frame-label { text-align: center; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); margin-top: 16px; }
  .m-nav { display: flex; border-top: 1px solid var(--border); background: var(--bg-card); padding: 8px 0; }
  .m-nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; padding: 4px; cursor: pointer; }
  .m-nav-item svg { width: 14px; height: 14px; color: var(--text-muted); }
  .m-nav-item.active svg { color: var(--cyan); }
  .m-nav-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--cyan); }
  .m-mic-screen { display: flex; flex-direction: column; align-items: center; gap: 14px; padding: 10px 0; }
  .m-wave { display: flex; align-items: center; gap: 2px; height: 24px; }
  .m-bar { width: 2px; background: var(--cyan); border-radius: 1px; animation: wave 1.4s ease-in-out infinite; opacity: 0.6; }
