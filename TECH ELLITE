class Nexa:
    def __init__(
        self,
        speaker: Speaker,
        listener: Listener,
        bus: CommandBus,
        emotion_detector: EmotionDetector,
        emotional_support: EmotionalSupportSkill,
        cfg: Config,
    ) -> None:
        self._speaker           = speaker
        self._listener          = listener
        self._bus               = bus
        self._emotion_detector  = emotion_detector
        self._emotional_support = emotional_support
        self._cfg               = cfg
        self._interaction_count = 0

    @classmethod
    def build(cls) -> "Nexa":
        cfg      = Config()
        speaker  = Speaker(cfg.voice_index)
        listener = Listener(cfg)
        emotion_detector  = EmotionDetector()
        emotional_support = EmotionalSupportSkill()

        skills: list[Skill] = [
            TimeSkill(),
            DateSkill(),
            WebSkill(),
            MusicSkill(listener),       # FIX: was missing from original build()
            ReminderSkill(listener),
            Email(listener),
            FileOpenSkill(),
        ]

        return cls(
            speaker, listener,
            CommandBus(skills, speaker),
            emotion_detector, emotional_support,
            cfg,
        )

    # FIX: moved _handle_emotion from FileOpenSkill into Nexa where it belongs
    def _handle_emotion(self, emotion: str, query: str) -> bool:
        """
        Handle detected emotion. Returns True if emotion was handled, False otherwise.
        """
        if emotion in ['sad', 'stressed']:
            log.info(f"User emotion detected as {emotion}. Providing emotional support.")
            self._emotional_support.run(query, self._speaker)

            # Listen for their preference
            response = self._listener.listen()

            # Provide the requested support
            if response:
                if "joke" in response:
                    self._emotional_support.provide_support("joke", self._speaker)
                elif "fact" in response:
                    self._emotional_support.provide_support("fun_fact", self._speaker)
                elif "motivat" in response:
                    self._emotional_support.provide_support("motivation", self._speaker)
                elif "music" in response:
                    self._emotional_support.provide_support("music", self._speaker)
                else:
                    self._emotional_support.provide_support("motivation", self._speaker)

            return True

        elif emotion == 'angry':
            self._speaker.say("I sense some frustration. Let me know how I can help you better.")
            return False

        return False

    def run(self) -> None:
        self._speaker.say(_greeting())  # initial greeting

        while True:
            # Periodically check emotion
            check_emotion = (
                self._interaction_count % self._cfg.emotion_check_interval == 0
            )

            if check_emotion and self._emotion_detector.enabled:
                query_result = self._listener.listen(return_audio=True)
                if isinstance(query_result, tuple):
                    query, audio_data = query_result
                else:
                    query      = query_result
                    audio_data = None
            else:
                query      = self._listener.listen()
                audio_data = None

            self._interaction_count += 1

            if not query:
                continue  # nothing heard — loop again

            # Check emotion if audio data is available
            if audio_data is not None and self._emotion_detector.enabled:
                emotion = self._emotion_detector.analyze_audio(audio_data)
                if self._handle_emotion(emotion, query):
                    continue  # Emotion was handled, skip to next iteration

            # check for exit commands
            if any(w in query for w in ("exit", "stop", "goodbye", "shut down")):
                self._speaker.say("Goodbye. Have a great day.")
                break

            # try to handle command
            if not self._bus.dispatch(query):
                self._speaker.say("Kindly repeat.")

