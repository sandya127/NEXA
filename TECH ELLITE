class OpenAIAssistant:
    """OpenAI GPT integration for intelligent responses"""
    
    def __init__(self, api_key: str = ""):
        self.enabled = OPENAI_AVAILABLE and api_key
        
        if self.enabled:
            openai.api_key = api_key
            self.conversation_history = []
            self.system_prompt = """You are Nexa, an advanced AI voice assistant. 
You are helpful, friendly, and concise. Keep responses brief and natural for voice interaction.
Provide specific, actionable information. Use a warm, professional tone."""
            log.info("OpenAI Assistant initialized")
        else:
            log.warning("OpenAI Assistant disabled")
    
    def get_response(self, user_input: str, context: Dict = None) -> str:
        """Get intelligent response from OpenAI"""
        if not self.enabled:
            return self._fallback_response(user_input)
        
        try:
            # Add user message to history
            self.conversation_history.append({
                "role": "user",
                "content": user_input
            })
            
            # Keep history manageable (last 10 exchanges)
            if len(self.conversation_history) > 20:
                self.conversation_history = self.conversation_history[-20:]
            
            messages = [
                {"role": "system", "content": self.system_prompt}
            ] + self.conversation_history
            
            response = openai.ChatCompletion.create(
                model=Config.OPENAI_MODEL,
                messages=messages,
                max_tokens=150,
                temperature=0.7
            )
            
            assistant_message = response.choices[0].message.content.strip()
            
            # Add to history
            self.conversation_history.append({
                "role": "assistant",
                "content": assistant_message
            })
            
            return assistant_message
            
        except Exception as e:
            log.error(f"OpenAI error: {e}")
            return self._fallback_response(user_input)
    
    def _fallback_response(self, user_input: str) -> str:
        """Simple fallback responses when OpenAI unavailable"""
        responses = {
            "hello": "Hello! How can I assist you today?",
            "how are you": "I'm functioning perfectly, thank you for asking!",
            "thank": "You're welcome! Happy to help.",
            "bye": "Goodbye! Have a great day!",
        }
        
        user_lower = user_input.lower()
        for key, response in responses.items():
            if key in user_lower:
                return response
        
        return "I understand. How else can I help you?"
    
    def reset_conversation(self):
        """Clear conversation history"""
        self.conversation_history = []

