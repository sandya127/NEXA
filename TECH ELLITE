#   WAKE WORD DETECTOR
# ──────────────────────────────────────────────────────────────────
class WakeWordDetector:
    """Listens for wake word using Porcupine"""
    
    def __init__(self, access_key: str, keywords: List[str] = ["jarvis"], 
                 sensitivity: float = 0.5):
        self.enabled = PORCUPINE_AVAILABLE and access_key
        self.running = False
        self.callback = None
        
        if not self.enabled:
            log.warning("Wake word detection disabled (Porcupine unavailable or no access key)")
            return
        
        try:
            self.porcupine = pvporcupine.create(
                access_key=access_key,
                keywords=keywords,
                sensitivities=[sensitivity] * len(keywords)
            )
            self.pa = pyaudio.PyAudio()
            self.stream = None
            log.info(f"Wake word detector initialized: {keywords}")
        except Exception as e:
            log.error(f"Failed to initialize Porcupine: {e}")
            self.enabled = False
    
    def start(self, callback):
        """Start listening for wake word"""
        if not self.enabled:
            return
        
        self.callback = callback
        self.running = True
        
        self.stream = self.pa.open(
            rate=self.porcupine.sample_rate,
            channels=1,
            format=pyaudio.paInt16,
            input=True,
            frames_per_buffer=self.porcupine.frame_length
        )
        
        threading.Thread(target=self._listen_loop, daemon=True).start()
        log.info("Wake word detection started")
    
    def stop(self):
        """Stop listening"""
        self.running = False
        if self.stream:
            self.stream.close()
        log.info("Wake word detection stopped")
    
    def _listen_loop(self):
        """Main listening loop"""
        while self.running:
            try:
                pcm = self.stream.read(self.porcupine.frame_length, 
                                      exception_on_overflow=False)
                pcm = struct.unpack_from("h" * self.porcupine.frame_length, pcm)
                
                keyword_index = self.porcupine.process(pcm)
                
                if keyword_index >= 0:
                    log.info("Wake word detected!")
                    if self.callback:
                        self.callback()
            except Exception as e:
                log.error(f"Wake word detection error: {e}")
                time.sleep(0.1)
    
    def cleanup(self):
        """Clean up resources"""
        self.stop()
        if self.enabled:
            if hasattr(self, 'porcupine'):
                self.porcupine.delete()
            if hasattr(self, 'pa'):
                self.pa.terminate()

