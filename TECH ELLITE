<script>
// ══════════════════════════════════════════════
//   CLOCK
// ══════════════════════════════════════════════
function updateClock() {
  const now = new Date();
  const h = String(now.getHours()).padStart(2,'0');
  const m = String(now.getMinutes()).padStart(2,'0');
  document.getElementById('clockDisp').innerHTML = h + '<span>:</span>' + m;
  document.getElementById('clockDate').textContent = now.toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric', year:'numeric'});
  document.getElementById('mobileTime').textContent = now.toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'});
}
document.getElementById('greetTime').textContent = new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});
updateClock();
setInterval(updateClock, 1000);

// ══════════════════════════════════════════════
//   STATE
// ══════════════════════════════════════════════
let msgCount          = 1;
let voiceCount        = 0;
let queryCount        = 0;
let reminderCount     = 0;
let reminders         = [];
let recognition       = null;
let micActive         = false;
let resultReceived    = false;   // FIX: guard so onend doesn't double-fire
let conversationHistory = [];

// ══════════════════════════════════════════════
//   TTS — FIX: proper async voice loading
// ══════════════════════════════════════════════
const synth = window.speechSynthesis;
let cachedVoices = [];
let voicesLoaded = false;

function loadVoices() {
  if (!synth) return;
  cachedVoices = synth.getVoices();
  if (cachedVoices.length > 0) voicesLoaded = true;
}

// Chrome loads voices async — must use onvoiceschanged
if (synth) {
  loadVoices(); // try immediately (works in Firefox)
  synth.onvoiceschanged = () => {
    loadVoices();
  };
}

function pickVoice() {
  if (!voicesLoaded) loadVoices();
  // Priority: Indian English female > any Indian English > any English female > any English
  return cachedVoices.find(v => v.lang === 'en-IN' && /female/i.test(v.name))
      || cachedVoices.find(v => v.lang === 'en-IN')
      || cachedVoices.find(v => /zira|susan|samantha|karen|moira|victoria|google uk english female/i.test(v.name))
      || cachedVoices.find(v => v.lang.startsWith('en-'))
      || cachedVoices[0]
      || null;
}

function nexaSpeak(text) {
  if (!synth) return;
  // FIX: cancel any ongoing speech first
  synth.cancel();

  function doSpeak() {
    const utt = new SpeechSynthesisUtterance(text);
    utt.lang  = 'en-IN';
    utt.rate  = 1.0;
    utt.pitch = 1.05;
    const voice = pickVoice();
    if (voice) utt.voice = voice;
    utt.onerror = (e) => {
      // 'interrupted' and 'canceled' are normal — user sent new message
      if (e.error !== 'interrupted' && e.error !== 'canceled') {
        console.warn('TTS error:', e.error);
      }
    };
    synth.speak(utt);
  }

  // FIX: if voices not loaded yet, wait up to 1.5s then speak anyway
  if (voicesLoaded) {
    doSpeak();
  } else {
    let tries = 0;
    const poll = setInterval(() => {
      loadVoices();
      tries++;
      if (voicesLoaded || tries >= 15) {
        clearInterval(poll);
        doSpeak();
      }
    }, 100);
  }
}

// ══════════════════════════════════════════════
//   COUNTS
// ══════════════════════════════════════════════
function updateCounts() {
  document.getElementById('msgCount').textContent      = msgCount + (msgCount === 1 ? ' message' : ' messages');
  document.getElementById('statQueries').textContent   = queryCount;
  document.getElementById('statVoice').textContent     = voiceCount;
  document.getElementById('statReminders').textContent = reminderCount;
}

// ══════════════════════════════════════════════
//   CHAT MESSAGES
// ══════════════════════════════════════════════
function addUserMessage(text) {
  const container = document.getElementById('chatMessages');
  const typing    = document.getElementById('typingMsg');
  const div = document.createElement('div');
  div.className = 'msg user';
  div.innerHTML = `
    <div class="msg-avatar user-av">U</div>
    <div class="msg-content">
      <div class="msg-bubble">${escHtml(text)}</div>
      <div class="msg-meta"><span>${nowStr()}</span></div>
    </div>`;
  container.insertBefore(div, typing);
  container.scrollTop = container.scrollHeight;
  msgCount++; queryCount++; updateCounts();
}

function addNexaMessage(html, emotion, emotionLabel) {
  const container = document.getElementById('chatMessages');
  const typing    = document.getElementById('typingMsg');
  typing.style.display = 'flex';
  container.scrollTop  = container.scrollHeight;

  setTimeout(() => {
    typing.style.display = 'none';
    const div = document.createElement('div');
    div.className = 'msg nexa';
    div.innerHTML = `
      <div class="msg-avatar nexa">N</div>
      <div class="msg-content">
        <div class="msg-bubble">${html}</div>
        <div class="msg-meta">
          <span class="emotion-badge ${emotion}">${emotionLabel}</span>
          <span>${nowStr()}</span>
        </div>
      </div>`;
    container.insertBefore(div, typing);
    container.scrollTop = container.scrollHeight;
    msgCount++; updateCounts();
  }, 700);
}

function nowStr() {
  return new Date().toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'});
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ══════════════════════════════════════════════
//   REMINDER HELPERS
// ══════════════════════════════════════════════
function parseTime(text) {
  const m = text.match(/(\d{1,2})[:\s]?(\d{2})?\s*(am|pm)?/i);
  if (!m) return null;
  let hour   = parseInt(m[1]);
  let minute = m[2] ? parseInt(m[2]) : 0;
  const ampm = m[3] ? m[3].toLowerCase() : null;
  if (ampm === 'pm' && hour !== 12) hour += 12;
  else if (ampm === 'am' && hour === 12) hour = 0;
  else if (!ampm && hour >= 1 && hour <= 7) hour += 12;
  const target = new Date();
  target.setHours(hour, minute, 0, 0);
  if (target <= new Date()) target.setDate(target.getDate() + 1);
  return target;
}

const dotClasses = ['rd-cyan','rd-green','rd-amber'];
let dotIdx = 0;

function addReminderToPanel(text, timeStr, dotClass) {
  const list  = document.getElementById('remindersList');
  const empty = list.querySelector('.reminder-empty');
  if (empty) empty.remove();
  const item = document.createElement('div');
  item.className = 'reminder-item';
  item.innerHTML = `
    <div class="reminder-dot ${dotClass}"></div>
    <div class="reminder-text">${escHtml(text)}</div>
    <div class="reminder-time">${timeStr}</div>`;
  list.appendChild(item);
  reminderCount++;
  document.getElementById('statReminders').textContent = reminderCount;
}

function scheduleReminder(about, target) {
  const delay = target - Date.now();
  if (delay <= 0) return;
  setTimeout(() => {
    addNexaMessage(`🔔 <strong>Reminder:</strong> ${escHtml(about)}`, 'remind', '◈ Reminder');
    nexaSpeak('Reminder: ' + about);
    reminderCount = Math.max(0, reminderCount - 1);
    document.getElementById('statReminders').textContent = reminderCount;
  }, delay);
}

// ══════════════════════════════════════════════
//   LOCAL SKILL DISPATCH
// ══════════════════════════════════════════════
function localDispatch(query) {
  const q = query.toLowerCase().trim();

  // TIME
  if (/\btime\b/.test(q) && !/remind/.test(q)) {
    const t = new Date().toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'});
    const reply = `The current time is ${t}. ⏰`;
    addNexaMessage(escHtml(reply), 'info', '◈ Precise');
    nexaSpeak(reply);
    return true;
  }

  // DATE
  if (/\bdate\b|\bday\b|\btoday\b/.test(q) && !/remind/.test(q)) {
    const d = new Date();
    const reply = `Today is ${d.toLocaleDateString('en-US', {weekday:'long', day:'numeric', month:'long', year:'numeric'})}. 📅`;
    addNexaMessage(escHtml(reply), 'info', '◈ Precise');
    nexaSpeak(reply);
    return true;
  }

  // MUSIC
  if (/\bplay\b/.test(q)) {
    const platform = /spotify/.test(q) ? 'spotify' : 'youtube';
    let song = q.replace(/play|on spotify|on youtube|in spotify|in youtube|spotify|youtube|song|track|music|please|for me/g,'').trim();
    if (!song) song = 'trending music';
    const encoded = encodeURIComponent(song);
    const url = platform === 'spotify'
      ? `https://open.spotify.com/search/${encoded}`
      : `https://www.youtube.com/results?search_query=${encoded}`;
    window.open(url, '_blank');
    const reply = `Opening <strong>${escHtml(song)}</strong> on ${platform === 'spotify' ? 'Spotify 🎵' : 'YouTube 🎬'}`;
    addNexaMessage(reply, 'music', '◈ Music');
    nexaSpeak(`Playing ${song} on ${platform}`);
    return true;
  }

  // OPEN WEBSITE
  const sites = {
    youtube:'https://youtube.com', google:'https://google.com', github:'https://github.com',
    maps:'https://maps.google.com', netflix:'https://netflix.com', spotify:'https://spotify.com',
    instagram:'https://instagram.com', linkedin:'https://linkedin.com', twitter:'https://twitter.com',
    amazon:'https://amazon.in', flipkart:'https://flipkart.com', zomato:'https://zomato.com',
    swiggy:'https://swiggy.com', gmail:'https://mail.google.com', drive:'https://drive.google.com',
    whatsapp:'https://web.whatsapp.com', telegram:'https://web.telegram.org',
    notion:'https://notion.so',
  };
  for (const [name, url] of Object.entries(sites)) {
    if (q.includes('open ' + name) || (q.includes('open') && q.includes(name))) {
      window.open(url, '_blank');
      const reply = `Opening <strong>${name}</strong> for you! 🌐`;
      addNexaMessage(reply, 'info', '◈ Web');
      nexaSpeak('Opening ' + name);
      return true;
    }
  }

  // REMINDER
  if (/remind|reminder|set reminder/.test(q)) {
    let about = '';
    const m1 = q.match(/remind(?:\s+me)?\s+(?:about|to|for)?\s+(.+?)(?:\s+at\s+|\s+by\s+|$)/i);
    if (m1) about = m1[1].trim();
    if (!about) {
      const m2 = q.match(/(.+?)\s+at\s+\d/i);
      if (m2) about = m2[1].replace(/remind(?:\s+me)?(?:\s+(?:about|to|for))?/i,'').trim();
    }
    if (!about) about = 'that important thing';
    const target = parseTime(q);
    if (target) {
      const timeStr  = target.toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'});
      const dotClass = dotClasses[dotIdx++ % dotClasses.length];
      addReminderToPanel(about, timeStr, dotClass);
      scheduleReminder(about, target);
      const reply = `Got it! I'll remind you about <strong>${escHtml(about)}</strong> at ${timeStr}. 🔔`;
      addNexaMessage(reply, 'remind', '◈ Reminder Set');
      nexaSpeak(`Reminder set for ${timeStr} about ${about}`);
    } else {
      const reply = `I'll set a reminder! What time should I remind you about <strong>${escHtml(about)}</strong>?`;
      addNexaMessage(reply, 'remind', '◈ Reminder');
      nexaSpeak('What time should I remind you?');
    }
    return true;
  }

  return false;
}

// ══════════════════════════════════════════════
//   CLAUDE AI
// ══════════════════════════════════════════════
async function getClaudeResponse(userMessage) {
  conversationHistory.push({ role: 'user', content: userMessage });

  const systemPrompt = `You are Nexa, a sleek, intelligent voice assistant. Keep responses concise (1-3 sentences) and conversational. Be warm and direct. Don't repeat the user's question.`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 200,
        system: systemPrompt,
        messages: conversationHistory,
      })
    });
    const data = await response.json();
    const text = data.content?.[0]?.text || "I'm having a moment — try again!";
    conversationHistory.push({ role: 'assistant', content: text });
    if (conversationHistory.length > 20) conversationHistory = conversationHistory.slice(-20);

    let emotion = 'think', label = '◈ Thinking';
    if (/joke|laugh|funny|😄|haha/i.test(text))     { emotion = 'fun';    label = '◈ Fun'; }
    else if (/time|date|clock/i.test(text))          { emotion = 'info';   label = '◈ Precise'; }
    else if (/remind|alarm/i.test(text))             { emotion = 'remind'; label = '◈ Reminder'; }
    else if (/music|song|play|spotify/i.test(text))  { emotion = 'music';  label = '◈ Music'; }
    else if (/help|sure|happy|glad/i.test(text))     { emotion = 'happy';  label = '◈ Helpful'; }
    return { text, emotion, label };
  } catch (err) {
    console.error('Claude API error:', err);
    return { text: "Sorry, I couldn't connect right now. Try again!", emotion: 'think', label: '◈ Offline' };
  }
}

// ══════════════════════════════════════════════
//   PROCESS INPUT (shared by text + voice)
// ══════════════════════════════════════════════
async function processInput(text) {
  text = text.trim();
  if (!text) return;

  addUserMessage(text);
  if (localDispatch(text)) return;

  // Fall through to Claude
  document.getElementById('typingMsg').style.display = 'flex';
  document.getElementById('chatMessages').scrollTop  = 99999;

  const { text: reply, emotion, label } = await getClaudeResponse(text);
  addNexaMessage(escHtml(reply), emotion, label);
  nexaSpeak(reply);
}

