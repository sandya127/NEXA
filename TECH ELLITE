        self.chat_display.tag_config("user", foreground="#4A9EFF", font=("Syne", 11, "bold"))
        self.chat_display.tag_config("nexa", foreground=Config.THEME_CYAN, font=("Syne", 11, "bold"))
        self.chat_display.tag_config("timestamp", foreground=Config.THEME_MUTED, font=("DM Mono", 9))
        self.chat_display.tag_config("emotion", foreground="#FFD700", font=("DM Mono", 9))
        
        # Bottom controls
        bottom_frame = tk.Frame(main_frame, bg=Config.THEME_BG)
        bottom_frame.pack(fill=tk.X, pady=(10, 0))
        
        # Settings button
        settings_btn = tk.Button(
            bottom_frame,
            text="⚙ Settings",
            font=("Syne", 10),
            bg=Config.THEME_CARD,
            fg=Config.THEME_MUTED,
            relief=tk.FLAT,
            padx=15,
            pady=5,
            command=self.show_settings,
            cursor="hand2"
        )
        settings_btn.pack(side=tk.LEFT)
        
        # Clear chat button
        clear_btn = tk.Button(
            bottom_frame,
            text="🗑 Clear Chat",
            font=("Syne", 10),
            bg=Config.THEME_CARD,
            fg=Config.THEME_MUTED,
            relief=tk.FLAT,
            padx=15,
            pady=5,
            command=self.clear_chat,
            cursor="hand2"
        )
        clear_btn.pack(side=tk.LEFT, padx=10)
    
    def add_message(self, sender: str, message: str, emotion: str = "neutral"):
        """Add message to chat display"""
        self.chat_display.config(state=tk.NORMAL)
        
        timestamp = datetime.datetime.now().strftime("%H:%M")
        
        if sender == "user":
            self.chat_display.insert(tk.END, f"\nYou", "user")
            self.chat_display.insert(tk.END, f" • {timestamp}", "timestamp")
            self.chat_display.insert(tk.END, f"\n{message}\n")
        else:
            self.chat_display.insert(tk.END, f"\nNexa", "nexa")
            self.chat_display.insert(tk.END, f" • {timestamp}", "timestamp")
            if emotion != "neutral":
                self.chat_display.insert(tk.END, f" • {emotion}", "emotion")
            self.chat_display.insert(tk.END, f"\n{message}\n")
        
        self.chat_display.see(tk.END)
        self.chat_display.config(state=tk.DISABLED)
    
    def update_status(self, text: str, state: str = "ready"):
        """Update status indicator"""
        colors = {
            "listening": Config.THEME_CYAN,
            "processing": "#FFD700",
            "ready": "#00FF00",
            "error": "#FF0000"
        }
        
        self.status_label.config(text=f"● {text.upper()}", fg=colors.get(state, Config.THEME_CYAN))
    
    def on_wake_word(self):
        """Called when wake word detected"""
        self.root.after(0, self._wake_word_ui_update)
    
    def _wake_word_ui_update(self):
        """UI updates for wake word (must run in main thread)"""
        self.add_message("system", "Wake word detected!", "info")
        self.toggle_listening()
    
    def toggle_listening(self):
        """Toggle listening state"""
        if self.is_listening:
            self.stop_listening()
        else:
            self.start_listening()
    
    def start_listening(self):
        """Start listening for user input"""
        self.is_listening = True
        self.update_status("Listening", "listening")
        self.mic_status.config(text="Listening... Speak now")
        self.mic_button.config(bg=Config.THEME_CYAN, fg=Config.THEME_BG)
        
        # Run listening in separate thread
        threading.Thread(target=self._listen_and_process, daemon=True).start()
    
    def stop_listening(self):
        """Stop listening"""
        self.is_listening = False
        self.update_status("Ready", "ready")
        self.mic_status.config(text="Tap to Start Listening")
        self.mic_button.config(bg=Config.THEME_BG, fg=Config.THEME_CYAN)
    
    def _listen_and_process(self):
        """Listen for audio and process it"""
        try:
            # Record audio
            audio_data = self.audio_handler.record_audio(duration=5)
            
            # Update UI
            self.root.after(0, lambda: self.update_status("Processing", "processing"))
            
            # Speech to text
            if self.google_services.enabled:
                text = self.google_services.speech_to_text(audio_data)
            else:
                text = "Speech recognition not available"
            
            if text:
                # Add to chat
                self.root.after(0, lambda: self.add_message("user", text))
                
                # Detect emotion
                emotion = self.emotion_detector.analyze_audio(audio_data)
                
                # Process command
                self.root.after(0, lambda: self.process_command(text, emotion))
            else:
                self.root.after(0, lambda: self.update_status("No speech detected", "ready"))
                
        except Exception as e:
            log.error(f"Listen error: {e}")
            self.root.after(0, lambda: self.update_status("Error", "error"))
        finally:
            self.root.after(0, self.stop_listening)
    
    def process_command(self, query: str, emotion: str = "neutral"):
        """Process user command"""
        # Check for skill match first
        for skill in self.skills:
            if skill.matches(query):
                response = skill.run(query, self)
                self.respond(response, emotion)
                return
        
        # Use OpenAI for general queries
        if self.openai_assistant.enabled:
            response = self.openai_assistant.get_response(query)
            self.respond(response, emotion)
        else:
            self.respond("I understand. How else can I help?", emotion)
    
    def respond(self, text: str, emotion: str = "neutral"):
        """Respond to user"""
        # Add to chat
        self.add_message("nexa", text, emotion)
        
        # Text to speech
        if self.google_services.enabled:
            audio_data = self.google_services.text_to_speech(text)
            if audio_data:
                threading.Thread(
                    target=self.audio_handler.play_audio,
                    args=(audio_data,),
                    daemon=True
                ).start()
        
        self.update_status("Ready", "ready")
    
    def clear_chat(self):
        """Clear chat history"""
        self.chat_display.config(state=tk.NORMAL)
        self.chat_display.delete(1.0, tk.END)
        self.chat_display.config(state=tk.DISABLED)
        self.openai_assistant.reset_conversation()
        self.conversation_history = []
    
    def show_settings(self):
        """Show settings dialog"""
        messagebox.showinfo(
            "Settings",
            "Settings panel coming soon!\n\n"
            "Configure:\n"
            "- Wake word sensitivity\n"
            "- Voice preferences\n"
            "- API keys\n"
            "- Emotion detection"
        )
    
    def on_closing(self):
        """Handle window closing"""
        if messagebox.askokcancel("Quit", "Do you want to quit Nexa?"):
            self.cleanup()
            self.root.destroy()
    
    def cleanup(self):
        """Clean up resources"""
        log.info("Cleaning up resources...")
        self.wake_detector.cleanup()
        self.audio_handler.cleanup()
    
    def run(self):
        """Run the application"""
        log.info("Nexa AI Assistant started")
        self.add_message("nexa", "Hello! I'm Nexa, your AI assistant. How can I help you today?")
        self.root.mainloop()

